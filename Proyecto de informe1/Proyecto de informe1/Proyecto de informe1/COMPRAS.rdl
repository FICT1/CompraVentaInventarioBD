      <rd:DataSourceID>e7fc6fb8-713a-43c3-88c0-0a6519e146ea</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    co.id_compra,
    co.fecha_compra,
    pr.nombre_proveedor,
    p.nombre_producto,
    dc.cantidad_compra,
    dc.precio_compra,
    dc.subtotal_compra,
    co.total_compra
FROM datos.compra co
INNER JOIN datos.proveedor pr ON pr.id_proveedor = co.id_proveedor
INNER JOIN datos.detallecompra dc ON dc.id_compra = co.id_compra
INNER JOIN datos.producto p ON p.id_producto = dc.id_producto
WHERE co.is_active = 1
ORDER BY co.fecha_compra, co.id_compra;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="id_compra">
          <DataField>id_compra</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="fecha_compra">
          <DataField>fecha_compra</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="nombre_proveedor">
          <DataField>nombre_proveedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nombre_producto">
          <DataField>nombre_producto</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cantidad_compra">
          <DataField>cantidad_compra</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="precio_compra">
          <DataField>precio_compra</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="subtotal_compra">
          <DataField>subtotal_compra</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="total_compra">
          <DataField>total_compra</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
