  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DataSource1</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>76b1812c-8f4f-40b5-b55a-0f991d28d901</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    pr.nombre_proveedor,
    COUNT(co.id_compra) AS cantidad_compras,
    SUM(co.total_compra) AS total_gastado
FROM datos.compra co
INNER JOIN datos.proveedor pr ON pr.id_proveedor = co.id_proveedor
WHERE co.is_active = 1
GROUP BY pr.nombre_proveedor
ORDER BY total_gastado DESC;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nombre_proveedor">
          <DataField>nombre_proveedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cantidad_compras">
          <DataField>cantidad_compras</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_gastado">
          <DataField>total_gastado</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
