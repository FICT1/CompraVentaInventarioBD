  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DataSource1</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>64826a01-2036-4f4b-9629-79f421a01c4f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    v.id_venta,
    v.fecha_venta,
    c.nombre_cliente,
    p.nombre_producto,
    dv.cantidad_venta,
    dv.precio_unitario,
    dv.subtotal,
    v.total_venta
FROM datos.venta v
INNER JOIN datos.cliente c ON c.id_cliente = v.id_cliente
INNER JOIN datos.detalleventa dv ON dv.id_venta = v.id_venta
INNER JOIN datos.producto p ON p.id_producto = dv.id_producto
WHERE v.is_active = 1
ORDER BY v.fecha_venta, v.id_venta;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="id_venta">
          <DataField>id_venta</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="fecha_venta">
          <DataField>fecha_venta</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="nombre_cliente">
          <DataField>nombre_cliente</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nombre_producto">
          <DataField>nombre_producto</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cantidad_venta">
          <DataField>cantidad_venta</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="precio_unitario">
          <DataField>precio_unitario</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="subtotal">
          <DataField>subtotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="total_venta">
          <DataField>total_venta</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
