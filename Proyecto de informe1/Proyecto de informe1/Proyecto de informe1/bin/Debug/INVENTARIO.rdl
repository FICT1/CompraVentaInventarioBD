  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
    p.nombre_producto,
    cat.nombre_categoria,
    m.nombre_marca,
    b.nombre_bodega,
    i.stock,
    i.stock_minimo,
    p.precio_venta
FROM datos.inventario i
INNER JOIN datos.producto p ON p.id_producto = i.id_producto
INNER JOIN datos.bodega b ON b.id_bodega = i.id_bodega
INNER JOIN datos.categoria cat ON cat.id_categoria = p.id_categoria
INNER JOIN datos.marca m ON m.id_marca = p.id_marca
WHERE i.is_active = 1
ORDER BY p.nombre_producto;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="nombre_producto">
          <DataField>nombre_producto</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nombre_categoria">
          <DataField>nombre_categoria</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nombre_marca">
          <DataField>nombre_marca</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nombre_bodega">
          <DataField>nombre_bodega</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="stock">
          <DataField>stock</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="stock_minimo">
          <DataField>stock_minimo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="precio_venta">
          <DataField>precio_venta</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
